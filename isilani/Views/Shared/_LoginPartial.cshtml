@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@{
    var isSignedIn = SignInManager.IsSignedIn(User);
}

@if (isSignedIn)
{
    <div class="navbar-text">
        @{ var user = await UserManager.GetUserAsync(User); }
        <span class="me-2">@user?.Email</span>
        <form asp-controller="Account" asp-action="LogoutPost" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-link nav-link p-0">Çıkış</button>
        </form>
    </div>
}
else
{
    <a class="nav-link d-inline" asp-area="Identity" asp-page="/Account/Login">Giriş</a>
    <a class="nav-link d-inline" asp-area="Identity" asp-page="/Account/Register">Kayıt</a>
}
