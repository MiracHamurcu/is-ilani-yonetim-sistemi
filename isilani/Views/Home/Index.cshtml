@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="container mt-4">
    <div class="row align-items-center">
        <div class="col-md-6">
            <h1 class="display-5">İş İlanı Yönetimi</h1>
            <p class="lead">İlanları listele, ekle, düzenle ve sil. Kategoriye göre filtreleme, arama ve sıralama özelliği bulunmaktadır.</p>
            <p>
                <a class="btn btn-primary btn-lg me-2" asp-controller="IsIlanlari" asp-action="Index">İlanlara Git</a>
                @if (!(User?.Identity?.IsAuthenticated ?? false))
                {
                    <a class="btn btn-outline-secondary btn-lg" asp-area="Identity" asp-page="/Account/Login">Giriş Yap</a>
                    <a class="btn btn-outline-primary btn-lg ms-2" asp-area="Identity" asp-page="/Account/Register">Kayıt Ol</a>
                }
            </p>
        </div>
        <div class="col-md-6 text-center">
            <div class="card p-3 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Site Durumu</h5>
                    <p class="card-text">Toplam İlan: <strong>@ViewBag.ToplamIlan</strong></p>
                    <p class="card-text">Toplam Kategori: <strong>@ViewBag.ToplamKategori</strong></p>
                </div>
            </div>
        </div>
    </div>
</div>
