@model isilani.Models.IsIlani
@{
    ViewData["Title"] = "İlan Sil";
}

<h1>İlan Sil</h1>

<div class="mb-3">
    <h4>@Model.Baslik</h4>
    <p>Firma: @Model.Sirket</p>
    <p>Kategori: @Model.IsKategori?.Ad</p>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button class="btn btn-danger">Sil</button>
    <a class="btn btn-secondary" asp-action="Index">İptal</a>
</form>
