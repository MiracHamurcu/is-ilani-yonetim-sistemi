@model isilani.Models.IsIlani
@{
    ViewData["Title"] = "İlan Düzenle";
}

<h1>İlan Düzenle</h1>

<form asp-action="Edit" method="post">
    @Html.ValidationSummary(false, "", new { @class = "text-danger" })
    @if (ViewBag.ModelErrors != null)
    {
        <div class="alert alert-danger">
            <ul>
            @foreach (var e in (List<KeyValuePair<string,string>>)ViewBag.ModelErrors)
            {
                <li>@e.Key: @e.Value</li>
            }
            </ul>
    @if (TempData["ModelErrors"] != null)
    {
        <pre class="text-danger">@TempData["ModelErrors"]</pre>
    }
        </div>
    }
    <input type="hidden" asp-for="Id" />
    <div class="mb-3">
        <label asp-for="Baslik" class="form-label"></label>
        <input asp-for="Baslik" class="form-control" />
        <span asp-validation-for="Baslik" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Sirket" class="form-label"></label>
        <input asp-for="Sirket" class="form-control" />
        <span asp-validation-for="Sirket" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Konum" class="form-label"></label>
        <input asp-for="Konum" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Maas" class="form-label"></label>
        <input asp-for="Maas" type="number" step="0.01" class="form-control" />
        <span asp-validation-for="Maas" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="IsKategoriId" class="form-label">Kategori</label>
        <select asp-for="IsKategoriId" class="form-select" asp-items="@(ViewBag.Kategoriler as SelectList)">
            <option value="">-- Kategori seçiniz --</option>
        </select>
        <span asp-validation-for="IsKategoriId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Aciklama" class="form-label"></label>
        <textarea asp-for="Aciklama" class="form-control"></textarea>
    </div>
    <button class="btn btn-primary">Kaydet</button>
    <a class="btn btn-secondary" asp-action="Index">İptal</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
